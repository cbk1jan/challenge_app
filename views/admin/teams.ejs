<%- include('../partials/header') %>
<div class="container-wide">
  <div class="page-header">
    <h1>👥 Teams</h1>
    <div class="d-flex gap-1 flex-wrap">
      <a href="/admin/export" class="btn btn-outline btn-sm">⬇️ CSV Export</a>
    </div>
  </div>

  <% if (success) { %><div class="alert alert-success">✅ <%= success %></div><% } %>
  <% if (error) { %><div class="alert alert-danger">⚠️ <%= error %></div><% } %>

  <div class="card">
    <div class="card-header">
      <h3>Neues Team</h3>
    </div>
    <div class="card-body">
      <form action="/admin/teams" method="POST" class="d-flex gap-2 flex-wrap align-center">
        <input type="text" name="name" class="form-control" placeholder="Teamname" required style="max-width:220px">
        <input type="number" name="points_override" class="form-control" placeholder="Bonuspunkte" value="0" style="max-width:140px">
        <button type="submit" class="btn btn-primary">Team anlegen</button>
      </form>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h3>Alle Teams (<%= teams.length %>)</h3>
    </div>
    <% if (teams.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">👥</div>
        <p>Noch keine Teams angelegt</p>
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Beitrittscode</th>
              <th>Punkte</th>
              <th>Gelöst</th>
              <th>Einreichungen</th>
              <th>Aktiv</th>
              <th>Aktionen</th>
            </tr>
          </thead>
          <tbody>
            <% teams.forEach(function(team) { %>
              <tr>
                <td><strong><%= team.name %></strong></td>
                <td><span class="join-code"><%= team.join_code %></span></td>
                <td><strong><%= team.total_points %></strong></td>
                <td><%= team.solved_count %></td>
                <td><%= team.submission_count %></td>
                <td>
                  <% if (team.session_token) { %>
                    <span class="badge badge-success">Online</span>
                  <% } else { %>
                    <span class="badge badge-secondary">Offline</span>
                  <% } %>
                </td>
                <td>
                  <div class="d-flex gap-1 flex-wrap">
                    <a href="/admin/teams/<%= team.id %>/edit" class="btn btn-sm btn-outline">✏️ Bearbeiten</a>
                    <% if (team.session_token) { %>
                      <form action="/admin/teams/<%= team.id %>/reset-session" method="POST" data-confirm="Sitzung für <%= team.name %> zurücksetzen?">
                        <button type="submit" class="btn btn-sm btn-warning">🔄 Sitzung</button>
                      </form>
                    <% } %>
                    <form action="/admin/teams/<%= team.id %>/delete" method="POST" data-confirm="Team '<%= team.name %>' wirklich löschen?">
                      <button type="submit" class="btn btn-sm btn-danger">🗑️</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
